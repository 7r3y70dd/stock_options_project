# Environment
ENVIRONMENT=dev
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stock_options

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Job scheduling intervals (in seconds)
DATA_REFRESH_INTERVAL=300
SIGNAL_GENERATION_INTERVAL=600
TRADE_MONITORING_INTERVAL=60

# Data providers
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
YFINANCE_ENABLED=true

# Frontend configuration
FRONTEND_API_BASE_URL=http://localhost:8000
FRONTEND_DASHBOARD_PREFIX=/api/api/dashboard
DEMO_USER_ID=1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
