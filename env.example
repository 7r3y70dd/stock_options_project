# Application Environment
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stock_options

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Job Scheduling Intervals (seconds)
DATA_REFRESH_INTERVAL=300
SIGNAL_GENERATION_INTERVAL=600
TRADE_MONITORING_INTERVAL=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend Configuration
FRONTEND_API_BASE_URL=http://localhost:8000
FRONTEND_DASHBOARD_PREFIX=/api/api/dashboard
DEMO_USER_ID=1

# Data Providers
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
YFINANCE_ENABLED=true

# Broker Configuration
BROKER_TYPE=paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
