# Application Environment
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://options_user:options_password@localhost:5432/options_tracker

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Data Provider Configuration
# Options: "mock", "alphavantage", "yfinance"
DATA_PROVIDER=mock

# Alpha Vantage API (https://www.alphavantage.co/)
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_RATE_LIMIT_CALLS_PER_MINUTE=5
ALPHAVANTAGE_CACHE_TTL_SECONDS=300

# yfinance Configuration
# yfinance is a convenient dev fallback for historical prices and options chains
# WARNING: Data is not suitable for production trading
# Automatically disabled in production environment
YFINANCE_ENABLED=True

# Other API Keys
POLYGON_API_KEY=
NEWS_API_KEY=

# Paper Trading
PAPER_TRADING_ENABLED=True
LIVE_TRADING_ENABLED=False
INITIAL_PORTFOLIO_VALUE=100000

# Risk Management
DEFAULT_RISK_LEVEL=medium
MAX_DAILY_LOSS_PCT=5.0

# Logging
LOG_LEVEL=INFO

# Job Scheduling (in seconds)
DATA_REFRESH_INTERVAL_SECONDS=300
SIGNAL_GENERATION_INTERVAL_SECONDS=600
TRADE_MONITORING_INTERVAL_SECONDS=60
