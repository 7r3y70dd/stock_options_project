# Options Tracker Environment Configuration

# API Keys and Credentials
ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here
POLYGON_API_KEY=your_polygon_key_here
NEWS_API_KEY=your_news_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./options_tracker.db

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

# Paper Trading
PAPER_TRADING_ENABLED=True
INITIAL_PORTFOLIO_VALUE=100000

# Live Trading (disabled by default)
LIVE_TRADING_ENABLED=False
BROKER_API_KEY=your_broker_api_key_here
BROKER_SECRET_KEY=your_broker_secret_key_here
